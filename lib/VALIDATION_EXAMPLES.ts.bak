/**
 * 📋 EXEMPLOS DE USO - PADRÃO DE VALIDAÇÃO
 * 
 * Copie estes padrões para TODAS as operações (programa, submissões, mensagens, etc.)
 */

import {
  validateProgramExists,
  validateSubmissionExists,
  validateCanSendMessage,
  getProgramData,
  getSubmissionData,
  ErrorMessages,
} from "@/lib/validation";

// ============================================
// ✅ EXEMPLO 1: EDITAR PROGRAMA
// ============================================

async function editProgram(programId: number, updates: any) {
  try {
    // ✅ VERIFICAÇÃO: Programa existe?
    const programExists = await validateProgramExists(programId);
    if (!programExists) {
      throw new Error(ErrorMessages.PROGRAM_NOT_FOUND);
    }

    // ✅ Se passou validação → permite UPDATE
    const { data, error } = await supabase
      .from("congress_program")
      .update(updates)
      .eq("id", programId)
      .select()
      .single();

    if (error) throw error;
    return data;
  } catch (error: any) {
    throw new Error(error.message || ErrorMessages.OPERATION_FAILED);
  }
}

// ============================================
// ✅ EXEMPLO 2: DELETAR PROGRAMA
// ============================================

async function deleteProgram(programId: number) {
  try {
    // ✅ VERIFICAÇÃO 1: Programa existe?
    const program = await getProgramData(programId);
    if (!program) {
      throw new Error(ErrorMessages.PROGRAM_NOT_FOUND);
    }

    // ✅ VERIFICAÇÃO 2: Pode deletar? (ex: não pode deletar se já passou)
    // const now = new Date();
    // if (new Date(program.date) < now) {
    //   throw new Error("Não pode deletar programa que já passou.");
    // }

    // ✅ Se passou validações → permite DELETE
    const { error } = await supabase
      .from("congress_program")
      .delete()
      .eq("id", programId);

    if (error) throw error;
  } catch (error: any) {
    throw new Error(error.message || ErrorMessages.OPERATION_FAILED);
  }
}

// ============================================
// ✅ EXEMPLO 3: EDITAR SUBMISSÃO (COM PROPRIEDADE)
// ============================================

async function editSubmission(submissionId: number, userId: number, updates: any) {
  try {
    // ✅ VERIFICAÇÃO 1: Submissão existe?
    const submission = await getSubmissionData(submissionId);
    if (!submission) {
      throw new Error(ErrorMessages.SUBMISSION_NOT_FOUND);
    }

    // ✅ VERIFICAÇÃO 2: Utilizador é proprietário?
    if (submission.user_id !== userId) {
      throw new Error(ErrorMessages.NOT_SUBMISSION_OWNER);
    }

    // ✅ Se passou validações → permite UPDATE
    const { data, error } = await supabase
      .from("submissions")
      .update(updates)
      .eq("id", submissionId)
      .select()
      .single();

    if (error) throw error;
    return data;
  } catch (error: any) {
    throw new Error(error.message || ErrorMessages.OPERATION_FAILED);
  }
}

// ============================================
// ✅ EXEMPLO 4: ENVIAR MENSAGEM
// ============================================

async function sendMessage(
  senderId: number,
  recipientId: number,
  content: string,
  submissionId?: number
) {
  try {
    // ✅ VERIFICAÇÃO: Pode enviar mensagem?
    const validation = await validateCanSendMessage(senderId, recipientId);
    if (!validation.valid) {
      throw new Error(validation.error || ErrorMessages.OPERATION_FAILED);
    }

    // ✅ Se passou validação → permite INSERT
    const { data, error } = await supabase
      .from("messages")
      .insert([{
        sender_id: senderId,
        recipient_id: recipientId,
        content,
        submission_id: submissionId || null,
      }])
      .select()
      .single();

    if (error) throw error;
    return data;
  } catch (error: any) {
    throw new Error(error.message || ErrorMessages.OPERATION_FAILED);
  }
}

// ============================================
// ✅ EXEMPLO 5: DELETAR SUBMISSÃO (COM PROPRIEDADE)
// ============================================

async function deleteSubmission(submissionId: number, userId: number) {
  try {
    // ✅ VERIFICAÇÃO 1: Submissão existe?
    const submission = await getSubmissionData(submissionId);
    if (!submission) {
      throw new Error(ErrorMessages.SUBMISSION_NOT_FOUND);
    }

    // ✅ VERIFICAÇÃO 2: Utilizador é proprietário?
    if (submission.user_id !== userId) {
      throw new Error(ErrorMessages.NOT_SUBMISSION_OWNER);
    }

    // ✅ VERIFICAÇÃO 3: Status permite deleção? (ex: não pode deletar se aprovada)
    // if (submission.status === "approved") {
    //   throw new Error("Não pode deletar submissão aprovada.");
    // }

    // ✅ Se passou validações → permite DELETE
    const { error } = await supabase
      .from("submissions")
      .delete()
      .eq("id", submissionId);

    if (error) throw error;
  } catch (error: any) {
    throw new Error(error.message || ErrorMessages.OPERATION_FAILED);
  }
}

// ============================================
// ✅ PADRÃO GENÉRICO - USE EM QUALQUER LUGAR
// ============================================

/**
 * Padrão Universal para qualquer operação
 * 
 * 1️⃣ ANTES de fazer qualquer coisa:
 *    - Verificar se os dados existem
 *    - Verificar permissões
 *    - Verificar constraints (regras de negócio)
 * 
 * 2️⃣ SE passou todas as verificações:
 *    - Permite a operação (INSERT/UPDATE/DELETE)
 * 
 * 3️⃣ SE teve erro:
 *    - Mostra mensagem traduzida amigável
 */

async function safeOperation(
  operationName: string,
  validations: Array<() => Promise<{ valid: boolean; error?: string }>>,
  execute: () => Promise<any>
) {
  try {
    // ✅ Executa TODAS as validações
    for (const validation of validations) {
      const result = await validation();
      if (!result.valid) {
        throw new Error(result.error || ErrorMessages.OPERATION_FAILED);
      }
    }

    // ✅ Se passou tudo → executa operação
    return await execute();
  } catch (error: any) {
    console.error(`[${operationName}] Erro:`, error.message);
    throw new Error(error.message || ErrorMessages.OPERATION_FAILED);
  }
}

